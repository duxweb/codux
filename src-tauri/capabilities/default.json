{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Codux desktop window.",
  "local": true,
  "windows": ["main", "settings", "project-create", "desktop-pet", "pet-claim", "pet-dex", "pet-custom-install", "terminal-*", "git-diff-*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "notification:default",
    "core:menu:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-start-dragging",
    "core:window:allow-outer-position",
    "core:window:allow-inner-size",
    "core:window:allow-scale-factor",
    "core:window:allow-current-monitor",
    "core:window:allow-primary-monitor",
    "core:window:allow-monitor-from-point",
    "core:window:allow-set-size",
    "core:window:allow-set-badge-count",
    "core:window:allow-set-badge-label",
    "core:window:allow-set-progress-bar"
  ]
}
